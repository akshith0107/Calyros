# =========================
# APP
# =========================
APP_ENV=development
APP_PORT=8000

# =========================
# DATABASE & REDIS
# =========================
DATABASE_URL=postgresql://user:pass@host/dbname
REDIS_URL=redis://localhost:6379/0

# =========================
# JWT AUTH & SECURITY
# =========================
# Generate securely via `openssl rand -hex 32`
SECRET_KEY=your_secret_key_here
REFRESH_SECRET_KEY=your_refresh_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# GROQ DETERMINISTIC PIPELINE
# =========================
GROQ_API_KEY_SCOUT=your_groq_api_key_scout_here
GROQ_MODEL_SCOUT=meta-llama/llama-4-scout-17b-16e-instruct

GROQ_API_KEY_CHAT=your_groq_api_key_chat_here
GROQ_MODEL_CHAT=openai/gpt-oss-120b

# Optional fallback
GROQ_API_KEY_BACKUP=

# =========================
# SUPABASE STORAGE
# =========================
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
