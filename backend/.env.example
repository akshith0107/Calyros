# =========================
# DATABASE (Neon Serverless Postgres / PostgreSQL)
# Note: All application tables and authentication data live here.
# PostgreSQL connection string for your database
# =========================
DATABASE_URL=postgresql://user:password@host/dbname

# =========================
# APP & ENVIRONMENT
# =========================
# development, staging, or production
ENVIRONMENT=development
# Port to run the application on
APP_PORT=8000
# Enable detailed error traces
DEBUG=true
# Comma-separated list of allowed frontend domains
BACKEND_CORS_ORIGINS=http://localhost:3000
# Max image upload size in MB
UPLOAD_MAX_SIZE_MB=10

# =========================
# JWT AUTH & SECURITY
# =========================
# Generate securely via `openssl rand -hex 32`
JWT_SECRET_KEY=your_secret_key_here
REFRESH_SECRET_KEY=your_refresh_secret_key_here
# Algorithm used for signing
JWT_ALGORITHM=HS256
# Token expiration in minutes (default 1440 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# AI MODELS & APIs
# =========================
# Google API Key for Gemini
GOOGLE_API_KEY=your_google_api_key_here
# Vision extraction model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Groq API Key for fast reasoning
GROQ_API_KEY=your_groq_api_key_here
# Groq Reasoning model (default: openai/gpt-oss-20b)
GROQ_REASONING_MODEL=openai/gpt-oss-20b

# =========================
# SUPABASE STORAGE (Image/File Buckets Only)
# Note: Used exclusively for the 'scans' bucket to upload food images.
# This does NOT host the database tables or authentication data.
# =========================
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =========================
# REDIS
# =========================
# Get this URL from Upstash Console -> Database -> Details -> "rediss://" (Python)
REDIS_URL=rediss://default:your_password_here@your_upstash_endpoint:6379
UPSTASH_REDIS_REST_URL="https://your_upstash_endpoint"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"
